class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int n = nums.length;
        int[] j = new int[n + 1];
        for (int i = 0; i < n; i++) {
            j[i + 1] = j[i] + nums[i];
        }
        int maxsum = Integer.MIN_VALUE;
        for (int i = 0; i <= n - k; i++) {
            int currentsum = j[i + k] - j[i];
            if (currentsum > maxsum) {
                maxsum = currentsum;
            }
        }
        return (double) maxsum/k;
    }
}
